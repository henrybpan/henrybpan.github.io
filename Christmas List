<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Christmas Wishlist - Henry B. Pan</title>
  <style>
    body {
      font-family: "Times New Roman", Times, serif;
      background: #fdfdfd;
      color: #708090;
      margin: 0;
      padding: 1rem 2rem 2rem 144px;
      text-align: left;
      max-width: 800px;
    }

    /* Mobile responsiveness */
    @media (max-width: 768px) {
      body {
        padding: 1rem 1rem 2rem 2rem;
        max-width: none;
      }
      
      h1 {
        font-size: 2rem;
      }
      
      nav a {
        margin: 0 0.8rem 0.3rem 0;
        display: inline-block;
      }
      
      .wishlist-item {
        flex-direction: column;
      }
      
      .wishlist-item img {
        width: 100%;
        max-width: 300px;
      }
    }

    /* Very small screens */
    @media (max-width: 480px) {
      body {
        padding: 1rem 0.5rem 2rem 1rem;
      }
      
      h1 {
        font-size: 1.5rem;
      }
      
      nav a {
        font-size: 0.9rem;
      }
    }

    h1 {
      margin-bottom: 0.5rem;
      font-size: 3rem;
    }

    /* Navigation links */
    nav {
      margin-bottom: 1rem;
    }
    nav a {
      display: inline-block;
      margin: 0 1rem 0 0;
      text-decoration: underline;
      color: #708090;
      font-size: 1.1rem;
    }
    nav a:hover { color: #505a66; }

    /* Separator line */
    hr {
      border: none;
      height: 1px;
      background-color: #dcdcdc;
      width: 40%;
      margin: 0.8rem 0;
    }

    /* Wishlist items */
    .wishlist-container {
      margin-top: 2rem;
    }

    .wishlist-item {
      display: flex;
      gap: 2rem;
      margin-bottom: 3rem;
      align-items: flex-start;
    }

    .wishlist-item img {
      width: 200px;
      height: 200px;
      object-fit: cover;
      border: 1px solid #dcdcdc;
    }

    .wishlist-item-details {
      flex: 1;
    }

    .wishlist-item-details h2 {
      margin: 0 0 0.5rem 0;
      font-size: 1.3rem;
    }

    .wishlist-item-details h2 a {
      color: #708090;
      text-decoration: underline;
    }

    .wishlist-item-details h2 a:hover {
      color: #505a66;
    }

    .wishlist-item-price {
      font-size: 1.1rem;
      color: #505a66;
      margin-bottom: 0.8rem;
      font-weight: bold;
    }

    .wishlist-item-description {
      font-size: 1.05rem;
      line-height: 1.6;
      color: #708090;
    }
  </style>
</head>
